AnonymousModule:
Match:
  MatchToken             'match'           KWMatch             tok=   0  pos=   0
  MatchExpr:
    Ident                'p'               Identifier          tok=   2  pos=   6
  WithToken              'with'            KWWith              tok=   4  pos=   8
  Rule:
    Bar                  '|'               OpBar               tok=   6  pos=  13
    Pat:
      Pat.Tuple:
        Pat.NamedSimple  'a'               Identifier          tok=   8  pos=  15
        Pat.NamedSimple  'b'               Identifier          tok=  11  pos=  18
