InfixApp    '+'               OpSubtractionAssignment  tok=   2  pos=   2
  Const     '1'               NumInt32            tok=   0  pos=   0
  InfixApp  '*'               OpMultiply          tok=   6  pos=   6
    Const   '2'               NumInt32            tok=   4  pos=   4
    Const   '3'               NumInt32            tok=   8  pos=   8
